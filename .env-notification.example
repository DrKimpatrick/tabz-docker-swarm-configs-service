PORT=8000
MODE=PROD

DATABASE_URI=
DATABASE_URI_JACKPOT=

JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

INTERNAL_JACKPOT_API_KEY=
# INTERNAL_JACKPOT_IP_WHITELIST=

# ─── SMS ─────────────────────────────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=
DMARK_USERNAME=
DMARK_PASSWORD=

# ─── Jackpot collection payments (Swarmbyte) ─────────────────────────────────
COLLECTION_PAYMENT_PROVIDER=SWARMBYTE
SWARMBYTE_BASE_URL=https://stg-api.swarmbyte.com

# Primary Swarmbyte merchant (jackpot pool)
SWARMBYTE_CLIENT_ID=
SWARMBYTE_CLIENT_SECRET=
SWARMBYTE_WALLET_ADDRESS=

# Backup Swarmbyte merchant (separate account — required for wallet routing)
SWARMBYTE_BACKUP_CLIENT_ID=
SWARMBYTE_BACKUP_CLIENT_SECRET=
SWARMBYTE_BACKUP_WALLET_ADDRESS=

SWARMBYTE_WALLET_ROUTING_ENABLED=false

API_BASE_URL_PRIMARY=https://ussd.tabzmedia.org
SWARMBYTE_WEBHOOK_PUBLIC_BASE_URL=https://ussd.tabzmedia.org

# Optional: send collect msisdn as 256XXXXXXXXX (default uses local format)
# SWARMBYTE_COLLECT_MSISDN_INTERNATIONAL=true

MONGO_MAX_POOL_SIZE=30
MONGO_MIN_POOL_SIZE=5
MONGO_AUTO_INDEX=false
